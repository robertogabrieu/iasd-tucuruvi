# --- SMTP / E-mail ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@iasdtucuruvi.com.br
SMTP_TO=contato@iasdtucuruvi.com.br
PORT=3001

# --- Banco de dados (Postgres) ---
# Em produção, deploy.sh gera POSTGRES_PASSWORD automaticamente.
# O host do banco é "db" (nome do serviço no docker-compose).
POSTGRES_USER=iasd
POSTGRES_PASSWORD=changeme
POSTGRES_DB=iasd
DATABASE_URL=postgres://iasd:changeme@db:5432/iasd

# --- Autenticação (JWT em cookie httpOnly) ---
# Gere segredos fortes: `openssl rand -hex 48`. deploy.sh faz isso por você.
JWT_ACCESS_SECRET=dev-access-secret-trocar
JWT_REFRESH_SECRET=dev-refresh-secret-trocar
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
CSRF_SECRET=dev-csrf-secret-trocar

# --- Seed do usuário inicial (executado uma vez no boot) ---
SEED_ADMIN_EMAIL=admin@iasdtucuruvi.com.br
SEED_ADMIN_PASSWORD=troque-no-primeiro-acesso
